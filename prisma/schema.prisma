/// Prisma schema for tc-project-service data model.
///
/// Notes:
/// - All primary/foreign identifiers use BigInt to mirror BIGINT columns.
/// - Most models use soft-delete fields (`deletedAt`, `deletedBy`) plus audit fields.
/// - `createdBy`/`updatedBy` store Topcoder user ids and are Int or BigInt by table.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  draft
  in_review
  reviewed
  active
  completed
  paused
  cancelled
}

enum InviteStatus {
  pending
  accepted
  refused
  requested
  request_rejected
  request_approved
  canceled
}

enum WorkStreamStatus {
  draft
  reviewed
  active
  completed
  paused
}

enum CopilotRequestStatus {
  new
  approved
  rejected
  seeking
  canceled
  fulfilled
}

enum CopilotApplicationStatus {
  pending
  invited
  accepted
  canceled
}

enum CopilotOpportunityStatus {
  active
  completed
  canceled
}

enum CopilotOpportunityType {
  dev
  qa
  design
  ai
  datascience
}

enum ScopeChangeRequestStatus {
  pending
  approved
  rejected
  activated
  canceled
}

enum CustomerPaymentStatus {
  canceled
  processing
  requires_action
  requires_capture
  requires_confirmation
  requires_payment_method
  succeeded
  refunded
  refund_failed
  refund_pending
}

enum ProjectMemberRole {
  manager
  observer
  customer
  copilot
  account_manager
  program_manager
  account_executive
  solution_architect
  project_manager
}

enum AttachmentType {
  file
  link
}

enum EstimationType {
  fee
  community
  topcoder_service
}

enum ValueType {
  int
  double
  string
  percentage
}

enum TimelineReference {
  project
  phase
  product
  work
}

enum PhaseApprovalDecision {
  approve
  reject
}

