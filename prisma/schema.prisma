generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  draft
  in_review
  reviewed
  active
  completed
  paused
  cancelled
}

model Project {
  id                    BigInt  @id @default(autoincrement())
  status                ProjectStatus
  name                  String
  description           String?
  projectFullText       String?
  billingAccountId      BigInt?
  directProjectId       BigInt?
  type                  String
  version               String?
  templateId            BigInt?
  estimatedPrice        Decimal?
  actualPrice           Decimal?
  cancelReason          String?
  terms                 String[]
  groups                String[]
  projectUrl            String?

  // Relations
  details               ProjectDetail?
  utm                   ProjectUtm?
  external              ProjectExternal?
  challengeEligibility  ChallengeEligibility[]
  estimation            ProjectEstimation[]
  attachments           ProjectAttachment[]
  bookmarks             ProjectBookmark[]
  members               ProjectMember[]
  memberInvites         ProjectMemberInvite[]
  phases                ProjectPhase[]

  createdAt             DateTime              @default(now())
  createdBy             BigInt
  updatedAt             DateTime?             @updatedAt
  updatedBy             BigInt?
  deletedAt             DateTime?
  deletedBy             BigInt?
  lastActivityAt        DateTime?
  lastActivityUserId    BigInt?
}


model ProjectDetail {
  id        BigInt @id @default(autoincrement())
  products    String[]
  intakePurpose   String?
  hideDiscussions Boolean?

  utm             ProjectDetailUtm?
  setting         ProjectDetailSetting?
  appDefinition   ProjectDetailAppDefinition?
  projectData     ProjectDetailProjectData?
  techstack       ProjectDetailTechstack?
  apiDefinition   ProjectDetailApiDefinition?

  // Relation
  project     Project @relation(fields: [projectId], references: [id])
  projectId BigInt @unique

  createdAt             DateTime              @default(now())
  createdBy             BigInt
  updatedAt             DateTime?             @updatedAt
  updatedBy             BigInt?

  @@index([projectId])
}

model ProjectDetailProjectData {
  id                      BigInt    @id @default(autoincrement())

  customerProject            String?
  executionHub               String?
  groupCustomerName          String?
  projectCode                String?
  groupName                  String?
  costCenter                 String?
  wbsCode                    String?
  onsiteEfforts              String?   @default("0")
  offshoreEfforts            String?   @default("0")
  plannedStartDate           DateTime?
  plannedEndDate             DateTime?
  partOfNg3                  String?
  companyCode                String?
  approvedAmount             String?
  projectClassificationCode  String?
  invoiceType                String?
  sowNumber                  String?
  sector                     String?
  smu                        String?
  subExecutionHub            String?
  initiatorEmail             String?

    // Relation
  projectDetail ProjectDetail @relation(fields: [projectDetailId], references: [id])
  projectDetailId BigInt @unique

  createdAt             DateTime              @default(now())
  createdBy             BigInt
  updatedAt             DateTime?             @updatedAt
  updatedBy             BigInt?

  @@index([projectDetailId])
}

model ProjectDetailUtm {
  id        BigInt @id @default(autoincrement())
  code      String?

  // Relation
  projectDetail ProjectDetail @relation(fields: [projectDetailId], references: [id])
  projectDetailId BigInt @unique

  createdAt             DateTime              @default(now())
  createdBy             BigInt
  updatedAt             DateTime?             @updatedAt
  updatedBy             BigInt?

  @@index([projectDetailId])
}

model ProjectDetailSetting {
  id        BigInt @id @default(autoincrement())

  workstreams   Boolean?

  // Relation
  projectDetail ProjectDetail @relation(fields: [projectDetailId], references: [id])
  projectDetailId BigInt @unique

  createdAt             DateTime              @default(now())
  createdBy             BigInt
  updatedAt             DateTime?             @updatedAt
  updatedBy             BigInt?

  @@index([projectDetailId])
}

model ProjectDetailTechstack {
  id                    BigInt @id @default(autoincrement())

  languages             String[]
  frameworks            String[]
  database              String?
  hosting               String?
  others                String?

  // Relation
  projectDetail ProjectDetail @relation(fields: [projectDetailId], references: [id])
  projectDetailId BigInt @unique

  createdAt             DateTime              @default(now())
  createdBy             BigInt
  updatedAt             DateTime?             @updatedAt
  updatedBy             BigInt?

  @@index([projectDetailId])
}

model ProjectDetailApiDefinition {
  id                    BigInt @id @default(autoincrement())

  addons                String[]
  deliverables          String[]
  deploymentTargets     String[]

  // Relation
  projectDetail ProjectDetail @relation(fields: [projectDetailId], references: [id])
  projectDetailId BigInt @unique

  createdAt             DateTime              @default(now())
  createdBy             BigInt
  updatedAt             DateTime?             @updatedAt
  updatedBy             BigInt?

  @@index([projectDetailId])
}

model ProjectDetailAppDefinition {
  id        BigInt @id @default(autoincrement())

  budget            Decimal?
  deliverables      String[]
  expectedOutcome   String[]
  designGoal        String[]
  needAdditionalScreens String?
  targetDevices     String[]
  webBrowserBehaviour   String?
  webBrowsersSupported  String[]
  hasBrandGuidelines    String?
  needSpecificFonts     String?
  needSpecificColors    String?
  securityRequirements  Json?
  userRequirements      Json?
  addons                Json?

  // Relation
  projectDetail ProjectDetail @relation(fields: [projectDetailId], references: [id])
  projectDetailId BigInt @unique

  createdAt             DateTime              @default(now())
  createdBy             BigInt
  updatedAt             DateTime?             @updatedAt
  updatedBy             BigInt?

  @@index([projectDetailId])
}

model ProjectUtm {
  id       BigInt @id @default(autoincrement())
  source   String?
  medium   String?
  campaign String?

  // Relation
  project     Project @relation(fields: [projectId], references: [id])
  projectId BigInt @unique

  createdAt             DateTime              @default(now())
  createdBy             BigInt
  updatedAt             DateTime?             @updatedAt
  updatedBy             BigInt?

  @@index([projectId])
}

enum ExternalType {
  github
  jira
  asana
  other
}

model ProjectExternal {
  id       BigInt @id @default(autoincrement())
  extId    String
  type     ExternalType
  data     String

  // Relation
  project     Project @relation(fields: [projectId], references: [id])
  projectId BigInt @unique

  createdAt             DateTime              @default(now())
  createdBy             BigInt
  updatedAt             DateTime?             @updatedAt
  updatedBy             BigInt?

  @@index([projectId])
}


enum EligibilityRole {
  submitter
  reviewer
  copilot
}

model ChallengeEligibility {
  id        BigInt @id @default(autoincrement())
  role      EligibilityRole

  // Relation
  project     Project @relation(fields: [projectId], references: [id])
  projectId BigInt
  users     BigInt[]
  groups    BigInt[]

  createdAt             DateTime              @default(now())
  createdBy             BigInt
  updatedAt             DateTime?             @updatedAt
  updatedBy             BigInt?

  @@index([projectId])
}


model ProjectEstimation {
  id                  BigInt @id @default(autoincrement())
  conditions          String
  price               Decimal
  quantity            Int?
  minTime             Int
  maxTime             Int
  buildingBlockKey    String
  metadata            ProjectEstimationMetadata?

  // Relation
  project     Project @relation(fields: [projectId], references: [id])
  projectId           BigInt

  createdAt             DateTime              @default(now())
  createdBy             BigInt
  updatedAt             DateTime?             @updatedAt
  updatedBy             BigInt?
  deletedAt             DateTime?
  deletedBy             BigInt?

  @@index([projectId])
}

model ProjectEstimationMetadata {
  id                  BigInt @id @default(autoincrement())

  deliverable         String?
  priceFormula        Int?

  // Relation
  estimation     ProjectEstimation @relation(fields: [projectEstimationId], references: [id])
  projectEstimationId           BigInt @unique

  createdAt             DateTime              @default(now())
  createdBy             BigInt
  updatedAt             DateTime?             @updatedAt
  updatedBy             BigInt?
  deletedAt             DateTime?
  deletedBy             BigInt?

  @@index([projectEstimationId])
}

model ProjectBookmark {
  id          BigInt @id @default(autoincrement())
  title       String
  address     String

  // Relation
  project     Project @relation(fields: [projectId], references: [id])
  projectId   BigInt

  createdAt             DateTime              @default(now())
  createdBy             BigInt
  updatedAt             DateTime?             @updatedAt
  updatedBy             BigInt?

  @@index([projectId])
}


enum AttachmentType {
  file
  link
}

enum ProjectMemberRole {
  manager
  observer
  customer
  copilot
  account_manager
  program_manager
  account_executive
  solution_architect
  project_manager
}

enum InviteStatus {
  pending
  accepted
  refused
  requested
  request_rejected
  request_approved
  canceled
}

model ProjectAttachment {
  id            Int      @id @default(autoincrement())
  title         String?
  type          AttachmentType
  tags          String[]
  size          Int?     @db.Integer // size in MB
  category      String?
  description   String?
  path          String
  contentType   String?
  allowedUsers  Int[]
  // Relationships
  project   Project @relation(fields: [projectId], references: [id])
  projectId BigInt

  deletedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime? @updatedAt
  deletedBy     BigInt?
  createdBy     BigInt
  updatedBy     BigInt?

  @@index([projectId])
}

model ProjectMember {
  id          BigInt               @id @default(autoincrement())
  userId      BigInt
  role        ProjectMemberRole
  isPrimary   Boolean              @default(false)
  handle      String
  email       String
  firstName   String?
  lastName    String?

  // Relationships
  project   Project @relation(fields: [projectId], references: [id])
  projectId BigInt

  deletedAt   DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime?            @updatedAt
  deletedBy   BigInt?
  createdBy   BigInt
  updatedBy   BigInt?

  @@index([projectId])
  @@index([userId])
}

model ProjectMemberInvite {
  id              BigInt             @id @default(autoincrement())
  userId          BigInt?
  email           String?
  applicationId   BigInt?
  role            ProjectMemberRole
  status          InviteStatus
  // Relationships
  project   Project @relation(fields: [projectId], references: [id])
  projectId BigInt

  createdAt       DateTime           @default(now())
  updatedAt       DateTime?          @updatedAt
  deletedAt       DateTime?
  createdBy       BigInt
  updatedBy       BigInt?
  deletedBy       BigInt?

  @@index([projectId])
  @@index([userId])
}

model ProjectPhase {
  id              BigInt             @id @default(autoincrement())

  name            String
  status          String
  spentBudget     Int?
  requirements    String?
  description     String?
  duration        Int?
  progress        Int?
  details         Json?
  startDate       DateTime
  endDate         DateTime
  budget          Int?
  order           Int?

  products        ProjectPhaseProduct[]
  members         ProjectPhaseMember[]

  // Relationships
  project   Project @relation(fields: [projectId], references: [id])
  projectId BigInt

  createdAt       DateTime           @default(now())
  updatedAt       DateTime?          @updatedAt
  createdBy       BigInt
  updatedBy       BigInt?

  @@index([projectId])
}

model ProjectPhaseProduct {
  id              BigInt             @id @default(autoincrement())

  actualPrice       Decimal?
  billingAccountId  BigInt?
  templateId        BigInt
  type              String
  estimatedPrice    Decimal?
  name              String
  details           Json?
  directProjectId   BigInt?
  projectId         BigInt

  // Relationships
  phase   ProjectPhase @relation(fields: [phaseId], references: [id])
  phaseId BigInt

  createdAt       DateTime           @default(now())
  updatedAt       DateTime?          @updatedAt
  deletedAt       DateTime?
  createdBy       BigInt
  updatedBy       BigInt?
  deletedBy       BigInt?

  @@index([phaseId])
}

model ProjectPhaseMember {
  id              BigInt             @id @default(autoincrement())

  userId          BigInt

  // Relationships
  phase   ProjectPhase @relation(fields: [phaseId], references: [id])
  phaseId BigInt

  createdAt       DateTime           @default(now())
  updatedAt       DateTime?          @updatedAt
  createdBy       BigInt
  updatedBy       BigInt?

  @@index([phaseId])
  @@index([userId])
}


model AccessRule {
  id              BigInt             @id @default(autoincrement())

  title           String?
  group           String?
  description     String?

  projectRoles    String[]
  topcoderRoles   String[]
  scopes          String[]

  createdAt       DateTime           @default(now())
  updatedAt       DateTime?          @updatedAt
  deletedAt       DateTime?
  createdBy       BigInt
  updatedBy       BigInt?
  deletedBy       BigInt?

  // Relations
  permissionWorkManagementPermissions WorkManagementPermission[] @relation("PermissionRule")
  allowWorkManagementPermissions      WorkManagementPermission[] @relation("AllowRule")
  denyWorkManagementPermissions       WorkManagementPermission[] @relation("DenyRule")
}

model WorkManagementPermission {
  id              BigInt             @id @default(autoincrement())
  policy          String
  projectTemplateId   BigInt

  permissionRuleId    BigInt?
  permission      AccessRule? @relation("PermissionRule", fields: [permissionRuleId], references: [id])
  allowRuleId     BigInt?
  allowRule       AccessRule? @relation("AllowRule", fields: [allowRuleId], references: [id])
  denyRuleId      BigInt?
  denyRule        AccessRule? @relation("DenyRule", fields: [denyRuleId], references: [id])

  createdAt       DateTime           @default(now())
  updatedAt       DateTime?          @updatedAt
  deletedAt       DateTime?
  createdBy       BigInt
  updatedBy       BigInt?
  deletedBy       BigInt?

  @@index([projectTemplateId])
}

model ProjectTemplate {
  id              BigInt             @id @default(autoincrement())

  name            String
  key             String
  category        String
  icon            String
  question        String
  info            String
  aliases         Json
  scope           Json?
  phases          Json?
  disabled        Boolean            @default(false)
  hidden          Boolean            @default(false)
  planConfig      Json?
  priceConfig     Json?
  form            Json?
  subCategory     String?
  metadata        Json               @default("{}")

  createdAt       DateTime           @default(now())
  updatedAt       DateTime?          @updatedAt
  deletedAt       DateTime?
  createdBy       BigInt
  updatedBy       BigInt?
  deletedBy       BigInt?
}

model ProjectHistory {
  id              BigInt             @id @default(autoincrement())

  projectId       BigInt
  status          ProjectStatus
  cancelReason    String?

  createdAt       DateTime           @default(now())
  updatedAt       DateTime?          @updatedAt
  updatedBy       BigInt?
}

model PlanConfig {
  id              BigInt             @id @default(autoincrement())

  key             String
  version         Int                @default(1)
  revision        Int                @default(1)
  config          Json

  createdAt       DateTime           @default(now())
  updatedAt       DateTime?          @updatedAt
  deletedAt       DateTime?
  createdBy       BigInt
  updatedBy       BigInt?
  deletedBy       BigInt?
}

model ProductTemplate {
  id              BigInt             @id @default(autoincrement())

  name            String
  productKey      String
  category        String
  subCategory     String?
  icon            String
  brief           String
  details         String
  aliases         Json
  form            Json?
  template        Json?

  createdAt       DateTime           @default(now())
  updatedAt       DateTime?          @updatedAt
  deletedAt       DateTime?
  createdBy       BigInt
  updatedBy       BigInt?
  deletedBy       BigInt?
}

enum WorkStreamStatus {
  draft
  reviewed
  active
  completed
  paused
}

model WorkStream {
  id              BigInt             @id @default(autoincrement())

  name            String
  type            String
  status          WorkStreamStatus

  createdAt       DateTime           @default(now())
  updatedAt       DateTime?          @updatedAt
  deletedAt       DateTime?
  createdBy       BigInt
  updatedBy       BigInt?
  deletedBy       BigInt?
}

model ProjectType {
  id              BigInt             @id @default(autoincrement())

  key             String
  displayName     String
  icon            String
  question        String
  info            String
  aliases         Json
  disabled        Boolean
  hidden          Boolean
  metadata        Json

  createdAt       DateTime           @default(now())
  updatedAt       DateTime?          @updatedAt
  deletedAt       DateTime?
  createdBy       BigInt
  updatedBy       BigInt?
  deletedBy       BigInt?
}