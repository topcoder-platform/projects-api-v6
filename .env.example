# PostgreSQL Database URL for Prisma
DATABASE_URL="postgresql://johndoe:mypassword@localhost:5432/projectdb?schema=projects"

# JWT Authentication
AUTH_SECRET="secret"
VALID_ISSUERS='["https://api.topcoder-dev.com", "https://api.topcoder.com","https://topcoder-dev.auth0.com/"]'

# Auth0 / bus API client configuration
AUTH0_URL="http://localhost:4000/oauth/token"
AUTH0_AUDIENCE="http://localhost:4000"
AUTH0_PROXY_SERVER_URL="http://localhost:4000/oauth/token"
AUTH0_CLIENT_ID="abc123"
AUTH0_CLIENT_SECRET="secret"
TOKEN_CACHE_TIME=86400000
BUSAPI_URL="http://localhost:4000/eventBus"
KAFKA_ERROR_TOPIC="common.error.reporting"

# Dedicated M2M configuration used by shared services
M2M_AUTH_URL="https://topcoder-dev.auth0.com/oauth/token"
M2M_AUTH_PROXY_SEREVR_URL="https://auth0proxy.topcoder-dev.com/token"
M2M_AUTH_AUDIENCE=""
M2M_AUTH_DOMAIN=""
M2M_AUTH_CLIENT_ID=""
M2M_AUTH_CLIENT_SECRET=""

# App configuration
PORT=3000
API_PREFIX="/v6"
MAX_PHASE_PRODUCT_COUNT=100
UNIQUE_GMAIL_VALIDATION=false
PRISMA_TRANSACTION_TIMEOUT=60000
PROJECT_SERVICE_PRISMA_TIMEOUT=10000
CORS_ALLOWED_ORIGIN=""
NODE_ENV=development

# External services
IDENTITY_SERVICE_ENDPOINT="http://localhost:4000/identity"
MEMBER_SERVICE_ENDPOINT="https://api.topcoder-dev.com/v5/members"
IDENTITY_API_URL=""
MEMBER_API_URL=""
BILLING_ACCOUNTS_API_URL=""
COPILOT_PORTAL_URL="https://copilots.topcoder-dev.com"
WORK_MANAGER_URL="https://challenges.topcoder-dev.com"
ACCOUNTS_APP_URL="https://accounts.topcoder-dev.com"

# Invite configuration
INVITE_EMAIL_SUBJECT="You are invited to Topcoder"
INVITE_EMAIL_SECTION_TITLE="Project Invitation"
SSO_REFCODES="[]"

# Salesforce billing-account integration
SALESFORCE_CLIENT_ID=""
SALESFORCE_CLIENT_AUDIENCE="https://login.salesforce.com"
SALESFORCE_AUDIENCE="https://login.salesforce.com"
SALESFORCE_SUBJECT=""
SALESFORCE_CLIENT_KEY=""
SALESFORCE_LOGIN_BASE_URL="https://login.salesforce.com"
SALESFORCE_API_VERSION="v37.0"
SFDC_BILLING_ACCOUNT_NAME_FIELD="Billing_Account_name__c"
SFDC_BILLING_ACCOUNT_MARKUP_FIELD="Mark_Up__c"
SFDC_BILLING_ACCOUNT_ACTIVE_FIELD="Active__c"
